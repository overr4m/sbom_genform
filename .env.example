# --- Пути (переопределяются через CLI-аргументы или docker -e) ---
REPO_ROOT=/app
# В Docker: монтируй свой проект в /app/project_inject
# Локально: по умолчанию используется examples/project_inject (уязвимый PHP-демо-проект)
PROJECT_DIR=/app/project_inject
OUTPUT_DIR=/app/secgensbom_out
REPORTS_DIR=/app/secgensbom_reports
DEP_CHECK_DATA=/app/.dependency-check-data

# --- Хостовые пути (при запуске scanner'ов внутри Docker) ---
HOST_PROJECT_DIR=
HOST_OUTPUT_DIR=
HOST_DEP_REPORT_DIR=
HOST_TRIVY_REPORT_DIR=

# --- Источник для генерации SBOM ---
# SOURCE=local | github | gitlab
SOURCE=local
# GIT_URL=https://github.com/org/repo
GIT_URL=
# GIT_TOKEN=ghp_...   (для приватных репо)
GIT_TOKEN=
# GIT_BRANCH=main
GIT_BRANCH=

# --- Сканирование образов ---
IMAGE_NAME=
CLAIR_ENDPOINT=http://clair:8080
SKIP_CLAIR=true

# --- GitHub API (для dependency.py — определение языков) ---
GITHUB_TOKEN=
